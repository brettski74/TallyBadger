#!/usr/bin/env python3
"""Regenerate expanded configuration seed from data/seed_data.tar.gz (#238).

May import the TallyBadger package (unlike tbload/tbsave). Requires ``jq`` on PATH
for JSON pretty-printing.
"""

from __future__ import annotations

import argparse
import gzip
import json
import shutil
import subprocess
import sys
import tarfile
import tempfile
from pathlib import Path
from typing import Any, NoReturn

from tallybadger.backup.snapshot import snapshot_uses_json_envelopes

DEPS_MK_HEADER = """\
# Generated by scripts/seed_regen.py — do not edit.
# Regenerate with: make -C data regen
"""


class SeedRegenError(Exception):
    """User-facing seed regen failure."""


def _die(message: str, *, code: int = 1) -> NoReturn:
    print(message, file=sys.stderr)
    raise SystemExit(code)


def _warn(message: str) -> None:
    print(f"warning: {message}", file=sys.stderr)


def require_jq() -> str:
    jq = shutil.which("jq")
    if jq is None:
        raise SeedRegenError("seed regen requires jq on PATH (pretty-print only; no -S)")
    return jq


def extract_archive(archive: Path, destination: Path) -> None:
    if not archive.is_file():
        raise SeedRegenError(f"seed archive not found: {archive}")
    destination.mkdir(parents=True, exist_ok=True)
    with gzip.open(archive, "rb") as gz:
        with tarfile.open(fileobj=gz, mode="r:") as tar:
            if not tar.getmembers():
                raise SeedRegenError(f"archive is empty: {archive}")
            tar.extractall(destination, filter="data")


def load_metadata(path: Path) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise SeedRegenError(f"cannot read metadata {path}: {exc}") from exc
    if not isinstance(data, dict):
        raise SeedRegenError("metadata.json root must be a JSON object")
    manifest = data.get("member_manifest")
    if not isinstance(manifest, list):
        raise SeedRegenError("metadata.member_manifest must be an array")
    return data


def manifest_paths(metadata: dict[str, Any]) -> list[str]:
    paths: list[str] = []
    for index, item in enumerate(metadata["member_manifest"]):
        if not isinstance(item, dict):
            raise SeedRegenError(f"member_manifest[{index}] must be an object")
        path = item.get("path")
        if not isinstance(path, str) or not path:
            raise SeedRegenError(f"member_manifest[{index}].path must be a non-empty string")
        paths.append(path)
    return paths


def assert_configuration_export(metadata: dict[str, Any]) -> None:
    export_type = metadata.get("export_type")
    if export_type != "configuration":
        raise SeedRegenError(
            f"seed archive export_type must be 'configuration', got {export_type!r}"
        )


def validate_envelope_member(path: str, raw: bytes, *, format_version: str) -> None:
    if not path.endswith(".json"):
        return
    try:
        data = json.loads(raw.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise SeedRegenError(f"{path} is not valid UTF-8 JSON: {exc}") from exc
    if not isinstance(data, dict):
        raise SeedRegenError(f"{path} must be a JSON envelope object, not {type(data).__name__}")
    if not snapshot_uses_json_envelopes(format_version):
        raise SeedRegenError(
            f"format_version {format_version!r} does not use JSON envelopes; "
            "configuration seed expects 2.0.0 tar.gz exports"
        )
    table = data.get("table")
    rows = data.get("rows")
    fv = data.get("format_version")
    if not isinstance(table, str) or not isinstance(rows, list) or not isinstance(fv, str):
        raise SeedRegenError(
            f"{path} must be a 2.0.0 envelope with format_version, table, and rows"
        )
    expected_table = path.removesuffix(".json")
    if table != expected_table:
        raise SeedRegenError(
            f"{path} envelope table {table!r} does not match filename (expected {expected_table!r})"
        )


def prettify_json(jq: str, raw: bytes) -> bytes:
    proc = subprocess.run(  # noqa: S603
        [jq, "."],
        input=raw,
        capture_output=True,
        check=False,
    )
    if proc.returncode != 0:
        detail = proc.stderr.decode("utf-8", errors="replace").strip()
        raise SeedRegenError(f"jq failed: {detail or proc.returncode}")
    return proc.stdout


def write_bytes(path: Path, body: bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_bytes(body)


def write_metadata_pretty(data_dir: Path, metadata: dict[str, Any], *, jq: str) -> None:
    raw = json.dumps(metadata, ensure_ascii=False).encode("utf-8")
    pretty = prettify_json(jq, raw)
    write_bytes(data_dir / "metadata.json", pretty)


def run_mkmeta(repo_root: Path, metadata_path: Path) -> None:
    mkmeta = repo_root / "scripts" / "mkmeta"
    if not mkmeta.is_file():
        raise SeedRegenError(f"mkmeta script not found: {mkmeta}")
    proc = subprocess.run(  # noqa: S603
        [sys.executable, str(mkmeta), "-i", str(metadata_path), "--quiet"],
        check=False,
        cwd=metadata_path.parent,
    )
    if proc.returncode != 0:
        raise SeedRegenError("mkmeta failed (see stderr above)")


def render_deps_mk(manifest_paths: list[str]) -> str:
    outputs = [*manifest_paths, "metadata.json"]
    lines = [DEPS_MK_HEADER.rstrip(), "", "SEED_MANIFEST_OUTPUTS := \\"]
    for index, path in enumerate(outputs):
        suffix = " \\" if index < len(outputs) - 1 else ""
        lines.append(f"  {path}{suffix}")
    lines.append("")
    for path in outputs:
        lines.append(f"{path}: seed_data.tar.gz")
    lines.append("")
    return "\n".join(lines)


def write_deps_mk(data_dir: Path, manifest_paths: list[str]) -> None:
    (data_dir / "seed_data.deps.mk").write_text(
        render_deps_mk(manifest_paths),
        encoding="utf-8",
    )


def find_orphan_json(data_dir: Path, manifest_paths: list[str]) -> list[str]:
    managed = set(manifest_paths) | {"metadata.json"}
    orphans: list[str] = []
    for path in sorted(data_dir.glob("*.json")):
        if path.name not in managed:
            orphans.append(path.name)
    return orphans


def warn_orphans(data_dir: Path, manifest_paths: list[str]) -> None:
    for name in find_orphan_json(data_dir, manifest_paths):
        _warn(f"orphan expanded JSON not in member_manifest: {name}")
        print(f"  rm -f {data_dir / name}", file=sys.stderr)


def regen(*, data_dir: Path, repo_root: Path) -> None:
    archive = data_dir / "seed_data.tar.gz"
    jq = require_jq()

    with tempfile.TemporaryDirectory(prefix="seed_regen_") as tmp_name:
        tmp = Path(tmp_name)
        extract_archive(archive, tmp)
        metadata_path = tmp / "metadata.json"
        if not metadata_path.is_file():
            raise SeedRegenError("archive is missing metadata.json")
        metadata = load_metadata(metadata_path)
        assert_configuration_export(metadata)
        format_version = metadata.get("format_version")
        if not isinstance(format_version, str):
            raise SeedRegenError("metadata.format_version must be a string")

        paths = manifest_paths(metadata)

        for member_path in paths:
            source = tmp / member_path
            if not source.is_file():
                raise SeedRegenError(f"archive missing manifest member: {member_path}")
            raw = source.read_bytes()
            dest = data_dir / member_path
            if member_path.endswith(".json"):
                validate_envelope_member(member_path, raw, format_version=format_version)
                write_bytes(dest, prettify_json(jq, raw))
            else:
                write_bytes(dest, raw)

        write_metadata_pretty(data_dir, metadata, jq=jq)
        run_mkmeta(repo_root, data_dir / "metadata.json")
        write_deps_mk(data_dir, paths)
        warn_orphans(data_dir, paths)


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="seed_regen",
        description="Regenerate expanded configuration seed from seed_data.tar.gz.",
    )
    parser.add_argument(
        "command",
        choices=["regen"],
        help="Subcommand (regen: extract archive and refresh expanded JSON)",
    )
    parser.add_argument(
        "--data-dir",
        type=Path,
        default=Path("."),
        help="data/ directory containing seed_data.tar.gz (default: cwd)",
    )
    parser.add_argument(
        "--repo-root",
        type=Path,
        default=None,
        help="Repository root (default: parent of scripts/ when invoked from repo)",
    )
    return parser.parse_args(argv)


def resolve_repo_root(explicit: Path | None) -> Path:
    if explicit is not None:
        return explicit.resolve()
    script = Path(__file__).resolve()
    return script.parent.parent


def main(argv: list[str] | None = None) -> None:
    args = parse_args(argv)
    data_dir = args.data_dir.resolve()
    repo_root = resolve_repo_root(args.repo_root)
    try:
        if args.command == "regen":
            regen(data_dir=data_dir, repo_root=repo_root)
    except SeedRegenError as exc:
        _die(str(exc))


if __name__ == "__main__":
    main()
