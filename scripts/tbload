#!/usr/bin/env python3
"""Restore a TallyBadger snapshot via POST /backup/import (#206, #253).

Standalone: stdlib + curl only. Copy this file anywhere Python 3.11+ and curl exist.
Does not import the TallyBadger application package.
"""

from __future__ import annotations

import argparse
import gzip
import io
import json
import os
import select
import shutil
import subprocess
import sys
import tarfile
import zipfile
from collections.abc import Iterator
from pathlib import Path
from typing import NoReturn
from urllib.parse import urlencode, urljoin

CANONICAL_RESTORE_MODES: tuple[str, ...] = ("abort", "overwrite", "erase-reload")
STDIN_READ_TIMEOUT_SECONDS = 30.0
IMPORT_CURL_WRITE_OUT = "\n%{http_code}"
GZIP_MAGIC = b"\x1f\x8b"
ZIP_MAGIC = b"PK\x03\x04"


class TbloadError(Exception):
    """User-facing tbload failure."""


class _GzipTarChunkWriter(io.BufferedIOBase):
    """Writable sink; gzip/tar output is drained as chunks."""

    def __init__(self) -> None:
        self._pending: list[bytes] = []

    def writable(self) -> bool:
        return True

    def write(self, b: bytes) -> int:
        if b:
            self._pending.append(bytes(b))
        return len(b)

    def flush(self) -> None:
        return None

    def drain(self) -> list[bytes]:
        out = self._pending
        self._pending = []
        return out


def _die(message: str, *, code: int = 1) -> NoReturn:
    print(message, file=sys.stderr)
    raise SystemExit(code)


def _info(message: str, *, quiet: bool) -> None:
    if not quiet:
        print(message, file=sys.stderr)


def maybe_warn_timeout_ignored_for_file_input(
    *,
    input_path: str | None,
    timeout_specified: bool,
) -> None:
    if input_path is not None and timeout_specified:
        print(
            "warning: --timeout applies only when reading from standard input; "
            "ignored when using -i/--input",
            file=sys.stderr,
        )


def resolve_restore_mode(user_input: str) -> str:
    """Strict prefix match against canonical restore mode names."""
    raw = user_input.strip()
    if not raw:
        raise TbloadError("restore mode must not be empty")

    lowered = raw.lower()
    matches = [mode for mode in CANONICAL_RESTORE_MODES if mode.startswith(lowered)]
    if not matches:
        raise TbloadError(
            f"unrecognized restore mode {user_input!r}; "
            f"expected one of {list(CANONICAL_RESTORE_MODES)} (prefixes allowed)"
        )
    if len(matches) > 1:
        raise TbloadError(f"ambiguous restore mode {user_input!r}; matches {matches}")
    return matches[0]


def build_base_url(*, base_url: str | None, host: str, port: int) -> str:
    if base_url:
        return base_url.rstrip("/")
    env = os.environ.get("TALLYBADGER_API_BASE_URL", "").strip()
    if env:
        return env.rstrip("/")
    return f"http://{host}:{port}"


def run_curl(args: list[str]) -> subprocess.CompletedProcess[bytes]:
    return subprocess.run(  # noqa: S603
        ["curl", *args],
        capture_output=True,
        check=False,
    )


def check_curl() -> None:
    if shutil.which("curl") is None:
        _die("tbload requires curl on PATH")


def require_directory_metadata_file(*, input_label: str, directory: Path) -> None:
    """Fail before HTTP when metadata.json is missing or not a regular file."""
    metadata_path = directory / "metadata.json"
    if not metadata_path.is_file():
        raise TbloadError(f"expected regular file {input_label}/metadata.json")


def detect_snapshot_container(prefix: bytes) -> str:
    """Return ``gzip`` or ``zip`` from leading magic bytes."""
    if prefix.startswith(GZIP_MAGIC):
        return "gzip"
    if prefix.startswith(ZIP_MAGIC):
        return "zip"
    raise TbloadError(
        "unrecognized snapshot container magic "
        f"(expected gzip {GZIP_MAGIC!r} or ZIP {ZIP_MAGIC!r})"
    )


def is_targz_path(path: str) -> bool:
    lowered = path.lower()
    return lowered.endswith(".tar.gz") or lowered.endswith(".tgz")


def is_zip_path(path: str) -> bool:
    return path.lower().endswith(".zip")


def collect_manifest_ordered_members(
    directory: Path,
    *,
    input_label: str,
) -> tuple[list[tuple[str, Path]], bytes]:
    """Return manifest-ordered (archive_name, source_path) pairs and metadata.json bytes."""
    require_directory_metadata_file(input_label=input_label, directory=directory)
    metadata_path = directory / "metadata.json"
    metadata_bytes = metadata_path.read_bytes()
    try:
        metadata_obj = json.loads(metadata_bytes.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise TbloadError(f"{input_label}/metadata.json is not valid JSON") from exc
    if not isinstance(metadata_obj, dict):
        raise TbloadError(f"{input_label}/metadata.json must be a JSON object")

    manifest = metadata_obj.get("member_manifest")
    if not isinstance(manifest, list):
        raise TbloadError("metadata.member_manifest must be a list")

    members: list[tuple[str, Path]] = []
    for index, entry in enumerate(manifest):
        if not isinstance(entry, dict):
            raise TbloadError(f"member_manifest[{index}] must be an object")
        path = entry.get("path")
        if not isinstance(path, str) or not path.strip():
            raise TbloadError(f"member_manifest[{index}].path must be a non-empty string")
        source = directory / path
        if source.is_symlink():
            raise TbloadError(f"refusing symlink {input_label}/{path}")
        if not source.is_file():
            raise TbloadError(f"expected regular file {input_label}/{path}")
        members.append((path, source))

    return members, metadata_bytes


def collect_directory_zip_members(directory: Path) -> list[tuple[str, Path]]:
    """Return (archive_name, source_path) pairs for legacy expanded snapshot ZIP packing."""
    members: list[tuple[str, Path]] = []

    for entry in sorted(directory.iterdir(), key=lambda path: path.name):
        if entry.is_symlink():
            continue
        if entry.is_file() and entry.suffix == ".json":
            members.append((entry.name, entry))

    attachments_dir = directory / "attachments"
    if attachments_dir.is_dir() and not attachments_dir.is_symlink():
        for path in sorted(attachments_dir.rglob("*")):
            if path.is_symlink():
                continue
            if path.is_file():
                archive_name = path.relative_to(directory).as_posix()
                members.append((archive_name, path))

    return members


def iter_pack_directory_to_targz(
    directory: Path,
    *,
    input_label: str,
    quiet: bool,
) -> Iterator[bytes]:
    """Pack expanded snapshot directory into tar.gz chunks (manifest order, metadata last)."""
    members, metadata_bytes = collect_manifest_ordered_members(
        directory,
        input_label=input_label,
    )
    _info(f"{input_label} is a directory (packing tar.gz)", quiet=quiet)

    archive_mtime = int((directory / "metadata.json").stat().st_mtime)
    writer = _GzipTarChunkWriter()
    with gzip.GzipFile(fileobj=writer, mode="wb", compresslevel=9) as gz:
        with tarfile.open(fileobj=gz, mode="w") as tar:
            for archive_name, source_path in members:
                _info(f"{input_label}/{archive_name}", quiet=quiet)
                data = source_path.read_bytes()
                info = tarfile.TarInfo(name=archive_name)
                info.size = len(data)
                info.mtime = archive_mtime
                tar.addfile(info, io.BytesIO(data))
            meta_info = tarfile.TarInfo(name="metadata.json")
            meta_info.size = len(metadata_bytes)
            meta_info.mtime = archive_mtime
            tar.addfile(meta_info, io.BytesIO(metadata_bytes))
        for part in writer.drain():
            yield part
    for part in writer.drain():
        yield part


def pack_directory_to_zip(
    directory: Path,
    *,
    input_label: str,
    quiet: bool,
) -> bytes:
    """Pack expanded snapshot directory contents into an in-memory ZIP (legacy)."""
    require_directory_metadata_file(input_label=input_label, directory=directory)
    _info(f"{input_label} is a directory", quiet=quiet)

    buffer = io.BytesIO()
    with zipfile.ZipFile(buffer, mode="w") as archive:
        for archive_name, source_path in collect_directory_zip_members(directory):
            _info(f"{input_label}/{archive_name}", quiet=quiet)
            archive.write(source_path, arcname=archive_name)

    return buffer.getvalue()


def _stdin_fd_or_error() -> int:
    try:
        return sys.stdin.fileno()
    except (AttributeError, ValueError, OSError) as exc:
        raise TbloadError(
            "standard input is not available for binary read; use -i/--input PATH"
        ) from exc


def iter_stdin_snapshot_chunks(
    *,
    timeout_seconds: float = STDIN_READ_TIMEOUT_SECONDS,
) -> Iterator[bytes]:
    """Yield snapshot bytes from stdin without concatenating into one buffer."""
    fd = _stdin_fd_or_error()
    ready, _, _ = select.select([fd], [], [], timeout_seconds)
    if not ready:
        raise TbloadError(
            f"no input received from standard input within {int(timeout_seconds)} seconds; "
            "pipe a tar.gz or ZIP file, or use -i/--input PATH"
        )

    while True:
        chunk = os.read(fd, 1024 * 1024)
        if not chunk:
            break
        yield chunk


def read_stdin_snapshot(*, timeout_seconds: float = STDIN_READ_TIMEOUT_SECONDS) -> bytes:
    """Read snapshot bytes from stdin (legacy helper; prefer streaming import)."""
    chunks = list(iter_stdin_snapshot_chunks(timeout_seconds=timeout_seconds))
    data = b"".join(chunks)
    if not data:
        raise TbloadError("empty snapshot read from standard input")
    return data


def preflight_health(base_url: str) -> None:
    url = urljoin(base_url + "/", "health")
    proc = run_curl(["-fsS", url])
    if proc.returncode != 0:
        err = proc.stderr.decode("utf-8", errors="replace").strip()
        _die(f"API health check failed for {url}: {err or proc.returncode}")


def extract_api_error_detail(body_text: str) -> str | None:
    """Return a human-readable API error from a FastAPI JSON body or raw text."""
    if not body_text.strip():
        return None
    try:
        payload = json.loads(body_text)
    except json.JSONDecodeError:
        return body_text.strip()
    if not isinstance(payload, dict):
        return body_text.strip()
    detail = payload.get("detail")
    if isinstance(detail, str):
        return detail
    if detail is not None:
        return json.dumps(detail, ensure_ascii=False)
    return body_text.strip()


def format_import_http_error(status_code: int, body_text: str, *, restore_mode: str) -> str:
    """Build operator-oriented import failure text from HTTP status and response body."""
    lines: list[str] = [f"Import failed (HTTP {status_code})."]

    if status_code == 409:
        lines.append(
            "The snapshot import conflicted with this database "
            "(duplicate keys or schema version mismatch)."
        )
    elif status_code == 400:
        lines.append(
            "The request or snapshot was rejected "
            "(invalid restore mode, format, integrity, or validation error)."
        )
    else:
        lines.append("The import request was not successful.")

    detail = extract_api_error_detail(body_text)
    if detail:
        lines.append(f"Server: {detail}")
    elif body_text.strip():
        lines.append(f"Server response: {body_text.strip()}")
    else:
        lines.append("The server did not return an error message in the response body.")

    detail_lower = (detail or "").lower()
    if status_code == 409 and restore_mode == "abort" and "duplicate key" in detail_lower:
        lines.append(
            "With restore mode abort, existing rows that share primary keys with the snapshot "
            "are not replaced. Use --mode overwrite to replace matching keys, or "
            "--mode erase-reload to wipe app data before loading (as make dbclean does)."
        )
    elif status_code == 409 and "snapshot has" in detail_lower and "database has" in detail_lower:
        lines.append(
            "Apply pending SQL migrations (make dbempty / tallybadger-migrate) or use a snapshot "
            "exported from a database at the same schema version as this target."
        )

    return "\n".join(lines)


def parse_curl_import_response(raw_stdout: bytes) -> tuple[str, int]:
    """Split curl import stdout into response body text and trailing HTTP status code."""
    if b"\n" not in raw_stdout:
        raise TbloadError("unexpected empty response from API")
    body_bytes, status_line = raw_stdout.rsplit(b"\n", 1)
    try:
        status_code = int(status_line.decode("ascii").strip())
    except ValueError as exc:
        raise TbloadError(f"invalid HTTP status from curl: {status_line!r}") from exc
    return body_bytes.decode("utf-8", errors="replace"), status_code


def _run_curl_import(
    curl_args: list[str],
    *,
    stdin_data: bytes | None = None,
    chunk_iter: Iterator[bytes] | None = None,
) -> subprocess.CompletedProcess[bytes]:
    if chunk_iter is not None:
        proc = subprocess.Popen(  # noqa: S603
            ["curl", *curl_args],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        assert proc.stdin is not None
        try:
            for chunk in chunk_iter:
                proc.stdin.write(chunk)
        finally:
            proc.stdin.close()
        stdout, stderr = proc.communicate()
        return subprocess.CompletedProcess(
            args=["curl", *curl_args],
            returncode=proc.returncode if proc.returncode is not None else 0,
            stdout=stdout,
            stderr=stderr,
        )

    return subprocess.run(  # noqa: S603
        ["curl", *curl_args],
        input=stdin_data,
        capture_output=True,
        check=False,
    )


def import_snapshot_raw(
    base_url: str,
    *,
    restore_mode: str,
    content_type: str,
    input_path: str | None = None,
    chunk_iter: Iterator[bytes] | None = None,
) -> dict[str, object]:
    """POST raw snapshot body to /backup/import?restore_mode=… (streaming when chunk_iter set)."""
    query = urlencode({"restore_mode": restore_mode})
    url = urljoin(base_url + "/", f"backup/import?{query}")
    curl_args = [
        "-sS",
        "-w",
        IMPORT_CURL_WRITE_OUT,
        "-X",
        "POST",
        "-H",
        f"Content-Type: {content_type}",
    ]
    if input_path is not None:
        curl_args.extend(["--data-binary", f"@{input_path}"])
        stdin_data: bytes | None = None
        stream_iter: Iterator[bytes] | None = None
    elif chunk_iter is not None:
        curl_args.extend(["--data-binary", "@-"])
        stdin_data = None
        stream_iter = chunk_iter
    else:
        raise TbloadError("import_snapshot_raw requires input_path or chunk_iter")

    curl_args.append(url)
    proc = _run_curl_import(curl_args, stdin_data=stdin_data, chunk_iter=stream_iter)
    if proc.returncode != 0:
        err = proc.stderr.decode("utf-8", errors="replace").strip()
        _die(f"Import request failed before a response was received: {err or proc.returncode}")

    try:
        body_text, status_code = parse_curl_import_response(proc.stdout)
    except TbloadError as exc:
        _die(str(exc))

    if status_code < 200 or status_code >= 300:
        _die(format_import_http_error(status_code, body_text, restore_mode=restore_mode))

    body_text = body_text.strip()
    try:
        data = json.loads(body_text) if body_text else {}
    except json.JSONDecodeError as exc:
        raise TbloadError(f"API returned non-JSON body: {body_text!r}") from exc
    if not isinstance(data, dict):
        raise TbloadError(f"expected JSON object from API, got {type(data).__name__}")
    return data


def import_snapshot_raw_gzip(
    base_url: str,
    *,
    restore_mode: str,
    input_path: str | None = None,
    chunk_iter: Iterator[bytes] | None = None,
) -> dict[str, object]:
    """POST raw tar.gz body (Content-Type: application/gzip)."""
    return import_snapshot_raw(
        base_url,
        restore_mode=restore_mode,
        content_type="application/gzip",
        input_path=input_path,
        chunk_iter=chunk_iter,
    )


def import_snapshot(
    base_url: str,
    *,
    restore_mode: str,
    container: str,
    input_path: str | None = None,
    chunk_iter: Iterator[bytes] | None = None,
) -> dict[str, object]:
    if container == "gzip":
        return import_snapshot_raw_gzip(
            base_url,
            restore_mode=restore_mode,
            input_path=input_path,
            chunk_iter=chunk_iter,
        )
    if container == "zip":
        return import_snapshot_raw(
            base_url,
            restore_mode=restore_mode,
            content_type="application/zip",
            input_path=input_path,
            chunk_iter=chunk_iter,
        )
    raise TbloadError(f"unsupported snapshot container {container!r}")


def report_success(data: dict[str, object]) -> None:
    print("Restore finished successfully.")
    for key in ("format_deprecation_warning",):
        value = data.get(key)
        if isinstance(value, str) and value.strip():
            print(value, file=sys.stderr)


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="tbload",
        description=(
            "Restore a TallyBadger backup via POST /backup/import (curl transport). "
            "Input may be a tar.gz or legacy ZIP file, an expanded snapshot directory "
            "(packed as tar.gz in metadata.member_manifest order), or a snapshot on stdin "
            "(streamed to curl without loading the full archive into memory)."
        ),
        add_help=False,
    )
    parser.add_argument(
        "--help",
        action="help",
        help="Show this help message and exit",
    )
    parser.add_argument(
        "-i",
        "--input",
        metavar="PATH",
        help=(
            "Snapshot tar.gz / legacy ZIP file, or expanded snapshot directory containing "
            "metadata.json (default: read tar.gz or ZIP from stdin; streamed, not buffered)"
        ),
    )
    parser.add_argument(
        "-m",
        "--mode",
        default="abort",
        help="Restore mode: abort, overwrite, or erase-reload (prefixes allowed; default: abort)",
    )
    parser.add_argument(
        "-b",
        "--base-url",
        help="API base URL (overrides host/port and TALLYBADGER_API_BASE_URL)",
    )
    parser.add_argument(
        "-h",
        "--host",
        default="127.0.0.1",
        help="API host when base URL not set (default: 127.0.0.1)",
    )
    parser.add_argument(
        "-p",
        "--port",
        type=int,
        default=8080,
        help="API port when base URL not set (default: 8080)",
    )
    parser.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="Suppress progress messages (for scripting)",
    )
    parser.add_argument(
        "-t",
        "--timeout",
        type=float,
        metavar="SECONDS",
        help="Seconds to wait for stdin input before failing (default: 30; stdin only)",
    )
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> None:
    check_curl()
    args = parse_args(argv)
    try:
        mode = resolve_restore_mode(args.mode)
    except TbloadError as exc:
        _die(str(exc))

    base_url = build_base_url(base_url=args.base_url, host=args.host, port=args.port)
    timeout_specified = args.timeout is not None
    timeout_seconds = args.timeout if timeout_specified else STDIN_READ_TIMEOUT_SECONDS
    if timeout_specified and timeout_seconds <= 0:
        _die("--timeout must be a positive number of seconds")

    maybe_warn_timeout_ignored_for_file_input(
        input_path=args.input,
        timeout_specified=timeout_specified,
    )

    input_label = args.input if args.input else "standard input"
    _info(f"Using {mode} restore mode.", quiet=args.quiet)

    input_path: str | None = None
    chunk_iter: Iterator[bytes] | None = None
    container: str

    if args.input is None:
        _info(f"Reading input from {input_label}.", quiet=args.quiet)
        try:
            chunk_source = iter_stdin_snapshot_chunks(timeout_seconds=timeout_seconds)
            first_chunk = next(chunk_source, b"")
            if not first_chunk:
                raise TbloadError("empty snapshot read from standard input")

            container = detect_snapshot_container(first_chunk)

            def chained_stdin() -> Iterator[bytes]:
                yield first_chunk
                yield from chunk_source

            chunk_iter = chained_stdin()
        except TbloadError as exc:
            _die(str(exc))
    elif os.path.isdir(args.input):
        directory = Path(args.input)
        try:
            chunk_iter = iter_pack_directory_to_targz(
                directory,
                input_label=args.input,
                quiet=args.quiet,
            )
        except TbloadError as exc:
            _die(str(exc))
        container = "gzip"
    else:
        _info(f"Reading input from {input_label}.", quiet=args.quiet)
        input_path = args.input
        if is_targz_path(args.input):
            container = "gzip"
        elif is_zip_path(args.input):
            container = "zip"
        else:
            with open(args.input, "rb") as handle:
                prefix = handle.read(4)
            try:
                container = detect_snapshot_container(prefix)
            except TbloadError as exc:
                _die(str(exc))

    _info(f"Connecting to {base_url}.", quiet=args.quiet)
    preflight_health(base_url)
    try:
        data = import_snapshot(
            base_url,
            restore_mode=mode,
            container=container,
            input_path=input_path,
            chunk_iter=chunk_iter,
        )
    except TbloadError as exc:
        _die(str(exc))

    if data.get("status") != "imported":
        _die(f"unexpected API status payload: {data!r}")
    report_success(data)


if __name__ == "__main__":
    main()
